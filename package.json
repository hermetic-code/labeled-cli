        "wrapper",
        "cleanup",
        "autoremove",
        "sysadmin",
        "devops",
        "tools"
    ],
    "engines": {
        "node": ">=18"
    },
    "main": "index.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hermetic-code/labeled-cli.git"
    },
    "bugs": {
        "url": "https://github.com/hermetic-code/labeled-cli/issues/new"
    },
    "homepage": "https://github.com/hermetic-code/labeled-cli#readme",
    "devDependencies": {
        "@types/node": "^20.19.43",
        "esbuild": "^0.28.1",
        "typescript": "^5.0.0"
    },
    "allowScripts": {
        "esbuild@0.28.1": true
    }
}

{
    "name": "labeled-cli",
    "version": "0.1.2",
    "description": "A transactional package manager wrapper to track, group, and cleanly purge temporary Linux installations without leaving orphan dependencies behind.",
    "author": "Joyal George K J",
    "license": "SEE LICENSE IN LICENSE",
    "bin": {
        "labeled": "dist/labeled"
    },
    "scripts": {
        "build": "node build.js"
    },
    "files": [
        "dist/labeled",
        "README.md",
        "LICENSE"
    ],
    "keywords": [
        "linux",
        "cli",
        "apt",
        "dnf",
        "dnf5",
        "pacman",
